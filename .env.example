# Copy to .env and fill in. .env is gitignored.

GEMINI_API_KEY=

# Optional — attach Hippocamp MCP for long-term memory.
# Install with: pip install ambi-core[hippocamp]
# Then set AMBI_USE_HIPPOCAMP=1. HIPPOCAMP_CMD is only needed if hippocamp-mcp
# isn't on your PATH (e.g. running from a non-activated venv).
AMBI_USE_HIPPOCAMP=
HIPPOCAMP_CMD=

# Optional — Obsidian vault integration.
# Set to the absolute path of your vault root. Tools (obsidian_save,
# obsidian_list, obsidian_search, obsidian_read, obsidian_delete) register
# automatically when set; agent reads/writes files directly on disk.
OBSIDIAN_VAULT=

TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to talk to the bot.
# Leave empty in dev to allow everyone (NOT recommended in production).
TELEGRAM_ALLOWED_USER_IDS=

# SenseGate read-side verification.
# 0 (default) = skip the LLM verifier on read-only turns — cheaper but no
#               read-side audit_log entries.
# 1           = verify every turn with tool calls — full observability,
#               one extra LLM call per read-only turn.
AMBI_VERIFY_READS=0